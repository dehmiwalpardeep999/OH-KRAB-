    {%- unless product.has_only_default_variant -%}
    {%- liquid
        assign blkst = block.settings
        assign cltype = settings.sw_type
        assign othervr = settings.othervr
        assign hidesoldout = ''
        if settings.swsold
            assign hidesoldout = 'hidesoldout'
        endif
        if isQuick
            if settings.qvrsold
                assign hidesoldout = 'hidesoldout'
            else
                assign hidesoldout = ''
            endif
            assign cltype = settings.cltype
            assign othervr = settings.othervr
        endif
    -%}
    <variant-selects id="variant-selects-{{ sectionId }}" class="db mb{{ blkst.bm | default: 20 }} {{ hidesoldout }}" data-section="{{ sectionId }}" data-msldier="pis{{ sectionId }}" data-url="{{ product.url }}"
        {%- if update_url == false %} data-update-url="false"{% endif %} {{ block.shopify_attributes }}>
        {%- for option in product.options_with_values -%}
        {%- liquid
            assign optionIndex = option.position | minus: 1
            assign is_color = false
            assign sizechart = false
            assign downcased_option = option.name | downcase
            assign colorOptions = settings.colorOpt | downcase | replace:", ","," | replace:" , ","," | replace:" ,","," | split: ","
            if colorOptions contains downcased_option
                assign is_color = true
            endif
            for value in option.values
            if value.swatch.image or value.swatch.color
                assign is_color = true
            endif
            endfor
            if sizeOptions contains downcased_option
                assign sizechart = true
            endif
        -%}
        {% capture sizechartlink %}
            {%- if sizechart and settings.sizechart_link -%}
                <a href="#sizechart" class="mfp sizelink" data-effect="mfp-zoom-in"><i class="at at-ruler"></i> {{ 'products.product.size_chart' | t }}</a>
            {%- endif -%}
        {% endcapture %}
        {%- if is_color and cltype != 'dd' -%}
            <fieldset class="product-form__input swatch fl f-wrap pvOpt{{ optionIndex }}">
                <div class="header">{{ option.name }}: <span class="ml5" data-opt="{{ option.name }}">{{- option.selected_value -}}</span></div>
                {%- render 'variant-options', product:product, product_form_id:product_form_id, sectionId:sectionId, option:option, cltype:cltype, othervr:othervr, is_color:is_color -%}
            </fieldset>
        {%- elsif is_color and cltype == 'dd' -%}
            <div class="product-form__input w_100 pvOpt{{ optionIndex }}">
            <label class="header" for="Option-{{ sectionId }}-{{ forloop.index0 }}">{{ option.name }}: <span class="ml5" data-opt="options[{{ option.name | escape }}]">{{- option.selected_value -}}</span></label>
                <select id="Option-{{ sectionId }}-{{ forloop.index0 }}" class="single-option-selector w_100" name="options[{{ option.name | escape }}]" form="{{ product_form_id }}">
                    {%- render 'variant-options', product: product, product_form_id:product_form_id, option:option, cltype:cltype, othervr:othervr -%}
                </select>
            </div>
        {%- elsif othervr == 'sw' -%}
            <fieldset class="product-form__input mfp-link swatch fl f-wrap pvOpt{{ optionIndex }}">
                <div class="header fl f-jcs f-aic mb5">
                    <span>{{ option.name }}: <span class="ml5" data-opt="{{ option.name }}">{{- option.selected_value -}}</span></span>
                    {{- sizechartlink -}}
                </div>
                {%- render 'variant-options', product:product, product_form_id:product_form_id, sectionId:sectionId, option: option, cltype:cltype, othervr:othervr, is_color: false -%}
            </fieldset>
        {%- else -%}
            <div class="product-form__input w_100 mfp-link pvOpt{{ optionIndex }}">
                <div class="header fl f-jcs f-aic mb5" for="Option-{{ sectionId }}-{{ forloop.index0 }}">
                    <span>{{ option.name }}: <span class="ml5" data-opt="options[{{ option.name | escape }}]">{{- option.selected_value -}}</span></span>
                    {{- sizechartlink -}}
                </div>
                <select id="Option-{{ sectionId }}-{{ forloop.index0 }}" class="single-option-selector w_100" name="options[{{ option.name | escape }}]" form="{{ product_form_id }}">
                    {%- render 'variant-options', product:product, product_form_id:product_form_id, option: option, cltype:cltype, othervr:othervr -%}
                </select>
            </div>
        {%- endif -%}
        {%- endfor -%}

        {% comment %} ===== CUSTOM SIZE MEASUREMENT FORM ===== {% endcomment %}
        <div id="custom-size-fields" style="display:none; margin-top: 16px;">
          <div class="csf-grid">
            <div class="csf-labels">
              <div class="csf-label">Top/Upper Length</div>
              <div class="csf-label">Shoulder</div>
              <div class="csf-label">Bust</div>
              <div class="csf-label">Hip</div>
              <div class="csf-label">Armhole</div>
              <div class="csf-label">Bicep</div>
              <div class="csf-label">Sleeve Length</div>
              <div class="csf-spacer"></div>
              <div class="csf-label">Lower Length</div>
              <div class="csf-label">Waist</div>
              <div class="csf-label">Thigh</div>
            </div>
            <div class="csf-inputs">
              <input type="text" name="properties[Top/Upper Length]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
              <input type="text" name="properties[Shoulder]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
              <input type="text" name="properties[Bust]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
              <input type="text" name="properties[Hip]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
              <input type="text" name="properties[Armhole]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
              <input type="text" name="properties[Bicep]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
              <input type="text" name="properties[Sleeve Length]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
              <div class="csf-spacer"></div>
              <input type="text" name="properties[Lower Length]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
              <input type="text" name="properties[Waist]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
              <input type="text" name="properties[Thigh]" form="{{ product_form_id }}" placeholder="inches/cm" class="csf-input">
            </div>
            <div class="csf-images">
              <div class="csf-img-box">
                <img src="https://cdn.shopify.com/s/files/1/0387/9609/9724/files/upper.png?v=1773213530" alt="Upper Body" loading="lazy">
                <span>Upper Measurements</span>
              </div>
              <div class="csf-img-box">
                <img src="https://cdn.shopify.com/s/files/1/0387/9609/9724/files/lower.png?v=1773213581" alt="Lower Body" loading="lazy">
                <span>Lower Measurements</span>
              </div>
            </div>
          </div>
          <div class="csf-notes">
            <label>Special Instructions</label>
            <textarea name="properties[Special Instructions]" form="{{ product_form_id }}" rows="3" placeholder="Any special requirements..."></textarea>
          </div>
        </div>

        <script type="application/json" id="variants{{ sectionId }}">{{ product.variants | json }}</script>
    </variant-selects>

    <style>
      #custom-size-fields { background:#fff; border:1px solid #e8e8e8; border-radius:8px; padding:20px; box-sizing:border-box; }
      .csf-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-bottom:20px; }
      .csf-labels, .csf-inputs { display:flex; flex-direction:column; gap:12px; }
      .csf-label { height:38px; display:flex; align-items:center; font-size:13px; font-weight:500; color:#1f2937; border-bottom:1px dotted #e5e7eb; }
      .csf-spacer { height:20px; }
      .csf-input { width:100%; height:38px; padding:0 10px; border:1px solid #d1d5db; border-radius:6px; font-size:13px; box-sizing:border-box; }
      .csf-input:focus { outline:none; border-color:#000; }
      .csf-images { display:flex; flex-direction:column; gap:16px; }
      .csf-img-box { background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px; padding:10px; text-align:center; }
      .csf-img-box img { width:100%; max-height:160px; object-fit:contain; }
      .csf-img-box span { display:block; font-size:11px; font-weight:600; text-transform:uppercase; color:#6b7280; margin-top:6px; }
      .csf-notes { display:flex; flex-direction:column; gap:6px; padding-top:16px; border-top:1px solid #f3f4f6; }
      .csf-notes label { font-size:13px; font-weight:600; color:#1f2937; }
      .csf-notes textarea { width:100%; padding:10px; border:1px solid #d1d5db; border-radius:6px; font-size:13px; font-family:inherit; resize:vertical; box-sizing:border-box; }
      .csf-notes textarea:focus { outline:none; border-color:#000; }
      @media(max-width:768px) {
        .csf-grid { grid-template-columns:1fr 1fr; }
        .csf-images { grid-column:span 2; flex-direction:row; }
      }
      @media(max-width:480px) {
        .csf-grid { grid-template-columns:1fr 1fr; gap:8px; }
        .csf-images { grid-column:span 2; flex-direction:row; }
        .csf-label { font-size:12px; height:34px; }
        .csf-input { height:34px; font-size:12px; }
      }
    </style>

    <script>
      (function(){
        function toggleCustomForm() {
          var el = document.getElementById('custom-size-fields');
          if (!el) return;

          var vs = document.querySelector('variant-selects');
          if (!vs) return;

          var isCustom = false;

          var radios = vs.querySelectorAll('input[type="radio"]:checked');
          for (var i = 0; i < radios.length; i++) {
            if (radios[i].value.toLowerCase().indexOf('custom') !== -1) { isCustom = true; break; }
          }

          if (!isCustom) {
            var selects = vs.querySelectorAll('select');
            for (var j = 0; j < selects.length; j++) {
              if (selects[j].value.toLowerCase().indexOf('custom') !== -1) { isCustom = true; break; }
            }
          }

          if (!isCustom) {
            var swatchLabels = vs.querySelectorAll('[data-opt]');
            for (var k = 0; k < swatchLabels.length; k++) {
              if (swatchLabels[k].textContent.toLowerCase().indexOf('custom') !== -1) { isCustom = true; break; }
            }
          }

          el.style.display = isCustom ? 'block' : 'none';
        }

        function init() {
          var vs = document.querySelector('variant-selects');
          if (!vs) return;
          vs.addEventListener('change', function(){ setTimeout(toggleCustomForm, 50); });
          toggleCustomForm();
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

    {%- endunless -%}

    {% if settings.goBuynowEnable %}
    <button type="button" class="disabled shopify-payment-button__button shopify-payment-button__button--unbranded" disabled onclick="onBuyNowClick(this)" id="gokwik-buy-now"{% if settings.hideFlow %} style="display:none !important;" {% endif %}>{{ settings.buynow-titile }}
    <div style="display:none" class="addloadr" id="abtn-loader"><div class="cir-loader">Loading..</div></div>
    </button>
    {% endif %}
