{%- assign section_set = section.settings -%}
<div class="content-indent {{ section_set.top-offeset}}{% if section_set.hide_mobile %} hide-sm{% endif %}{% if section_set.hided %} hide-md hide-lg{% endif %}">      
    <div class="section-cover id-{{section.id}} wow fadeIn" style="background:{% if section_set.bgg != blank %}{{ section_set.bgg }}{% else %}{{section_set.bg}}{% endif %};padding:{{ section_set.text-padding}}px 10px;border-radius:{{section_set.br}}px;">    
        <div class="{% unless section_set.section_width %} page-width{% else %} fullwidth{% if section_set.npd %} npd{% endif %}{% endunless %}"  style="--tcl:{{section_set.cl}};--tfs:{{section_set.fs}}px;--tfsm:{{section_set.fsm}}px;--tff:var(--{{section_set.ff}});--tfw:{{section_set.fw}};--tlh:{{section_set.lh}};">   
		<div class="fl f-jcsb f-aic timerbar tc f-wrap">
          <div class="ttlTxt">{%- if section_set.infolines != blank %}{{ section_set.infolines }}{%- endif -%}  </div>	
           {% if section_set.hero_dealtimer %}
                    <div class="fl atCounter tc mb0 ttlTxt" data-date="{{section_set.cnt_date}}">
                      <span class="ttu"><span class="tm days">00</span> {{'date_formats.days' | t}}</span><span class="colon">:</span><span><span class="tm hours">00</span></span><span class="colon">:</span><span><span class="tm minutes">00</span></span><span></span>
                    </div>
          {% endif %}
          {% if section_set.button_label != blank and section_set.url != blank %}
           <a href="{{section_set.url}}" class="btn {{section_set.btn-size-mob}} {{section_set.btn-size-desk}} {{section_set.btn-style}}">{{ section_set.button_label }}</a>
          {% endif %}      	
        </div>		
    </div> 
  </div>
</div> 
{% schema %}
  {
    "name": "t:sections.textline.name",
    "class": "index-section",   	
	"settings":[	
	 {
            "type": "select",
            "id": "top-offeset",
            "label": "t:sections.all.top_offSet",
            "default": "default",
            "options": [
              {
                "value": "default",
                "label": "Default"
              },
              {
                "value": "small",
                "label": "Small"
              },
			  {
                "value": "none",
                "label": "None"
              }
			]
        },	
       {
		"type":"checkbox",
		"id":"section_width",
		"label":"t:global.fullwidth",
		"default": true
	  },
	  {
			"type":"checkbox",
			"id":"npd",
			"label":"t:global.no_padding",
			"info": "t:global.no_padding_info",
			"default": true
	 },
      {
            "type": "checkbox",
            "id": "hide_mobile",
            "label": "t:global.devices.mobile_hide",
            "default": false
        },
       {
            "type": "checkbox",
            "id": "hided",
            "label":"t:global.devices.desktop_hide",
            "default": false
        },
      	{
            "type": "color",
            "id": "bg",
            "label": "t:global.background.color",
			"default":"#EF9797"	
		 },
        {
            "type": "color_background",
            "id": "bgg",
            "label": "t:global.background.gradient"
        },		
		{
        "type": "range",
        "id": "br",
        "min": 0,
        "max": 30,
        "step": 1,
        "label": "t:global.background.radius",
        "unit": "px",
        "default": 0
		},
		{
        "type": "textarea",
        "id": "infolines",
        "label": "t:global.text.text",
        "default": "HOLIDAY SALE IS ON UNTIL"   
        },      
      {
        "type": "header",
        "content": "t:sections.hero.countdown"
      },
 	  {
		"type":"checkbox",
		"id":"hero_dealtimer",
		"label":"t:global.display",
		"default": true,
		"info": "t:sections.hero.countdown_info"
	  },
	  {
        "type": "text",
        "id": "cnt_date",
        "label": "t:sections.hero.enter_date",
        "info": "t:sections.hero.date_info",
        "default": "12\/20\/2025"
      },  
     {
        "type": "paragraph",
        "content": "-----------------------------------------------"
      },
       {
        "type": "text",
        "id": "button_label",
        "label": "t:global.button.text",
		"default": "SHOP COLLECTION"
      },
      {
                "type": "url",
                "id": "url",
                "label": "t:global.link",
                "default":"/"
        },
      {
            "type": "select",
            "id": "btn-style",
            "label": "t:global.button.select",
            "default": "bdr-btn2",
            "options": [
              {
              "label": "Solid Button 1",
              "value": "btn"
              },
              {
              "label": "Solid Button 2",
              "value": "btn2"
              },
              {
              "label": "Solid Button 3",
              "value": "btn3"
              },
              {
              "label": "Border Button 1",
              "value": "bdr-btn1"
              },
              {
              "label": "Border Button 2",
              "value": "bdr-btn2"
              } 
            ]
        },
	  {
          "type": "select",
          "id": "btn-size-desk",
          "label": "t:global.button.size",
          "default": "btn-md",
          "options": [
            { "label": "Small", "value": "btn-sm" },
            { "label": "Medium", "value": "btn-md" },
            { "label": "Large", "value": "btn-lg" }	
          ]
	  },
      {
        "type": "paragraph",
        "content": "-----------------------------------------------"
      },
		{
            "type": "color",
            "id": "cl",
            "label": "t:global.color.text",
			"default":"#fff"	
		 },
      {
		"type": "range",
		"id": "fs",
		"label": "t:global.font.size",
		"default": 30,
		"min": 10,
		"max": 100,
		"step": 1,
		"unit": "px"
	},
	{
		"type": "range",
		"id": "fsm",
		"label": "t:global.font.size_mobile",
		"default": 25,
		"min": 10,
		"max": 60,
		"step": 1,
		"unit": "px"
	},
	{
		"type": "select",
		"id": "ff",
		"label": "t:global.font.family",
		"default": "ft2",
		"options": [
			{
				"value": "ft1",
				"label": "Font 1"
			},
			{
				"value": "ft2",
				"label": "Font 2"
			},
			{
				"value": "ft3",
				"label": "Font 3"
			}
		]
	},
	{
		"type": "select",
		"id": "fw",
		"label": "t:global.font.weight",
		"default": "600",
		"options": [
			{
				"value": "300",
				"label": "Light"
			},
			{
				"value": "400",
				"label": "Regular"
			},
			{
				"value": "500",
				"label": "Medium"
			},
			{
				"value": "600",
				"label": "Semi Bold"
			},
			{
				"value": "700",
				"label": "Bold"
			}
		]
	}, 	
	{
		"type": "range",
		"id": "lh",
		"label": "t:global.font.height",
		"default": 1.3,
		"min": 1.0,
		"max": 2.0,
		"step": 0.1,
		"info": "t:global.font.height_info"
	},
	 {
		"type": "range",
		"id": "text-padding",
		"label": "t:sections.textline.padding",
		"min": 5,
		"max": 50,
		"step": 1,
		"unit": "px",
		"default": 30
	 }	
	
	],
	"presets": [
      {
		 "name": "t:sections.textline.name",
         "category": "Text"
	 }
   ]
  }
{% endschema %}

